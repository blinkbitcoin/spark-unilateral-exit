{
  "name": "spark-unilateral-exit",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "bin": {
    "spark-unilateral-exit": "./src/cli.ts"
  },
  "scripts": {
    "test": "vitest run --coverage",
    "test:unit": "vitest run",
    "test:e2e": "RUN_SPARK_E2E=1 vitest run test/e2e --testTimeout 300000",
    "typecheck": "tsc --noEmit",
    "plan": "node src/cli.ts plan",
    "refresh-bundle": "node src/cli.ts refresh-bundle",
    "refresh-recovery-bundle": "nix develop --command cargo run --manifest-path tools/spark-recovery-bundle/Cargo.toml --"
  },
  "dependencies": {
    "@buildonspark/spark-sdk": "^0.8.6",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.7.0",
    "@scure/bip32": "^1.7.0",
    "@scure/bip39": "^1.6.0",
    "@scure/btc-signer": "^1.5.0"
  },
  "//": [
    "overrides: @buildonspark/spark-sdk depends on ua-parser-js ^2.x, which is",
    "AGPL-3.0-or-later (relicensed from MIT at v2.0). AGPL is incompatible with",
    "this repo's MIT license for redistributed bundles, so we pin the last",
    "MIT-licensed major (1.x). The SDK only uses it for user-agent detection",
    "and the UAParser API it uses is compatible across 1.x/2.x."
  ],
  "overrides": {
    "ua-parser-js": "^1.0.41"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.18"
  }
}
